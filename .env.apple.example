ASR_API_HOST=localhost
ASR_API_PORT=43556
ASR_API_KEY=change-me

ASR_DEFAULT_MODEL=qwen-1.7b
ASR_DEFAULT_DEVICE=cpu

ASR_MODEL_ALIAS_MAP="whisper-1=turbo,turbo=turbo,large-v3=large-v3,distil=distil-multi4,distil-multi4=distil-multi4,qwen-0.6b=qwen3-asr-0.6b,qwen-1.7b=qwen3-asr-1.7b,qwen-1.7b-edit-max=qwen3-asr-1.7b,qwen3-asr-0.6b=qwen3-asr-0.6b,qwen3-asr-1.7b=qwen3-asr-1.7b"
ASR_MODEL_PROFILE_MAP="qwen-1.7b-edit-max=edit-max-v1"
ASR_MODEL_SOURCE_MAP="turbo=turbo,large-v3=large-v3,distil-multi4=./models/distil-multi4-ct2,qwen3-asr-0.6b=Qwen/Qwen3-ASR-0.6B,qwen3-asr-1.7b=Qwen/Qwen3-ASR-1.7B"
ASR_MODEL_FAMILY_MAP="turbo=whisper,large-v3=whisper,distil-multi4=whisper,qwen3-asr-0.6b=qwen,qwen3-asr-1.7b=qwen"
ASR_MODEL_BACKEND_MAP="turbo=faster-whisper,large-v3=faster-whisper,distil-multi4=faster-whisper,qwen3-asr-0.6b=qwen-mlx-worker,qwen3-asr-1.7b=qwen-mlx-worker"
ASR_MODEL_DEVICE_MAP="turbo=cpu,large-v3=cpu,distil-multi4=cpu,qwen3-asr-0.6b=mlx,qwen3-asr-1.7b=mlx"
ASR_MODEL_COMPUTE_TYPE_MAP="turbo=int8,large-v3=int8,distil-multi4=int8,qwen3-asr-0.6b=float16,qwen3-asr-1.7b=float16"
ASR_MODEL_IDLE_SECONDS_MAP="turbo=600,large-v3=600,distil-multi4=600,qwen3-asr-0.6b=5400,qwen3-asr-1.7b=5400"
ASR_MODEL_CAPABILITIES_MAP="turbo=transcribe|translate|timestamps|stream|realtime,large-v3=transcribe|translate|timestamps|stream|realtime,distil-multi4=transcribe|translate|timestamps|stream|realtime,qwen3-asr-0.6b=transcribe|timestamps|stream|realtime,qwen3-asr-1.7b=transcribe|timestamps|stream|realtime"
ASR_MODEL_VAD_MAP="turbo=false,large-v3=false,distil-multi4=false,qwen3-asr-0.6b=false,qwen3-asr-1.7b=false"
ASR_MODEL_GPU_MEMORY_RESERVATION_MB_MAP="turbo=0,large-v3=0,distil-multi4=0,qwen3-asr-0.6b=0,qwen3-asr-1.7b=0"
ASR_MODEL_MAX_CONCURRENT_REQUESTS_MAP="turbo=1,large-v3=1,distil-multi4=1,qwen3-asr-0.6b=1,qwen3-asr-1.7b=1"
ASR_MODEL_ALIGNER_SOURCE_MAP="qwen3-asr-0.6b=Qwen/Qwen3-ForcedAligner-0.6B,qwen3-asr-1.7b=Qwen/Qwen3-ForcedAligner-0.6B"
ASR_MODEL_ALIGNER_DEVICE_MAP="qwen3-asr-0.6b=mlx,qwen3-asr-1.7b=mlx"
ASR_MODEL_ALIGNER_DTYPE_MAP="qwen3-asr-0.6b=float16,qwen3-asr-1.7b=float16"
ASR_MODEL_RUNTIME_PYTHON_MAP="qwen3-asr-0.6b=./.venv-qwen-mlx/bin/python,qwen3-asr-1.7b=./.venv-qwen-mlx/bin/python"

# Edit-max runs only for batch verbose_json transcription. Values are exposed
# for reproducible tuning; defaults favor conservative, non-clipping boundaries.
ASR_EDIT_MAX_VAD_START_THRESHOLD=0.50
ASR_EDIT_MAX_VAD_END_THRESHOLD=0.35
ASR_EDIT_MAX_MIN_SPEECH_MS=64
ASR_EDIT_MAX_MIN_SILENCE_MS=96
ASR_EDIT_MAX_ENERGY_WINDOW_MS=10
ASR_EDIT_MAX_ENERGY_SEARCH_MS=192
ASR_EDIT_MAX_ENERGY_SILENCE_RUN_MS=30
ASR_EDIT_MAX_ENERGY_SPEECH_RUN_MS=20
ASR_EDIT_MAX_ENERGY_NOISE_PERCENTILE=20.0
ASR_EDIT_MAX_ENERGY_NOISE_MULTIPLIER=3.0
ASR_EDIT_MAX_ENERGY_MIN_DBFS=-60.0
ASR_EDIT_MAX_ENERGY_MAX_DBFS=-35.0
ASR_EDIT_MAX_WORD_ASSOCIATION_MS=240
ASR_EDIT_MAX_OUTER_WORD_SNAP_MS=240
ASR_EDIT_MAX_VAD_ONLY_MIN_PEAK=0.80
ASR_EDIT_MAX_VAD_ONLY_MIN_MEAN=0.60

ASR_DIARIZATION_ENABLED=true
ASR_DIARIZATION_BACKEND=pyannote
ASR_DIARIZATION_MODEL_ID=pyannote/speaker-diarization-community-1
ASR_DIARIZATION_MODEL_PATH=./models/pyannote-speaker-diarization-community-1
ASR_DIARIZATION_DEVICE=cpu
ASR_DIARIZATION_IDLE_SECONDS=1800
ASR_DIARIZATION_RUNTIME_PYTHON=./.venv-diarization/bin/python
ASR_DIARIZATION_STARTUP_TIMEOUT_SECONDS=300
ASR_DIARIZATION_REQUEST_TIMEOUT_SECONDS=3600
# Setup-only secret; runtime launchers remove it before starting the API.
ASR_DIARIZATION_SETUP_HF_TOKEN=
PYANNOTE_METRICS_ENABLED=0

ASR_GPU_MEMORY_BUDGET_MB=8192
ASR_MAX_LOADED_MODELS_CPU=1
ASR_MAX_CONCURRENT_REQUESTS_PER_MODEL=1
ASR_UPLOAD_CHUNK_SIZE=1048576
ASR_CPU_THREADS=0
ASR_LOG_LEVEL=INFO
