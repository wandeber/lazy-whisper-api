#!/usr/bin/env bash
set -euo pipefail

# Wrapper script committed to the repo.
# The actual ffmpeg binary is provided by imageio-ffmpeg inside the venv.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV_PYTHON="$SCRIPT_DIR/../.venv/bin/python"

FFMPEG_EXE="$("$VENV_PYTHON" -c 'import imageio_ffmpeg; print(imageio_ffmpeg.get_ffmpeg_exe())')"
exec "$FFMPEG_EXE" "$@"
